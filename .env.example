# Core
NODE_ENV=development
APP_URL=http://localhost:3000

# No-auth embedded mode (default)
ENABLE_AUTH=false
DEFAULT_WORKSPACE_SLUG=demo-store
EMBED_SHARED_SECRET=replace-with-long-random-secret

# MySQL / Prisma
DATABASE_URL=mysql://root:root@localhost:3306/competitor_ad_intelligence

# Redis / BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Optional AI enhancement (deterministic analysis still works without this)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional Meta Ad Library runtime connector
META_AD_LIBRARY_ACCESS_TOKEN=
META_AD_LIBRARY_API_VERSION=v22.0

# Object storage (S3 compatible)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=competitor-ad-intelligence
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Admin safety key for ingestion control endpoints
ADMIN_API_KEY=local-admin-key
NEXT_PUBLIC_ADMIN_API_KEY=local-admin-key
