{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@cia/ai": ["ai/src/index.ts"],
      "@cia/ai/*": ["ai/src/*"],
      "@cia/analytics": ["analytics/src/index.ts"],
      "@cia/analytics/*": ["analytics/src/*"],
      "@cia/db": ["db/src/index.ts"],
      "@cia/db/*": ["db/src/*"],
      "@cia/ingestion": ["ingestion/src/index.ts"],
      "@cia/ingestion/*": ["ingestion/src/*"],
      "@cia/types": ["types/src/index.ts"],
      "@cia/types/*": ["types/src/*"],
      "@cia/ui": ["ui/src/index.ts"],
      "@cia/ui/*": ["ui/src/*"],
      "@cia/utils": ["utils/src/index.ts"],
      "@cia/utils/*": ["utils/src/*"]
    }
  }
}
